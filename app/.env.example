# CELESTUAL — frontend environment (Vite). Copy to .env.local for local dev, and
# set the same two vars in Vercel → Project → Settings → Environment Variables.
#
# CELESTUAL's Supabase project uses the `celestual_*` tables.
# Find these in Supabase → Project Settings → Data API / API Keys.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ── Feature flags (all OFF by default → dev-friendly, nothing gated/broken) ──
# Each flag turns a scaffolded integration from its safe local fallback into the
# real, server-backed behavior. Set to 1 only once the matching backend is live.

# Instagram DM handle verification (NO Facebook OAuth). When 1, people prove the @
# they type is really theirs by DMing a one-time code to your Instagram account —
# verified by Meta's official Messaging webhook. Requires migration 0004 + the
# celestual-ig-webhook edge function (see docs/DEBUG-IG-WEBHOOK.md). When 0, the
# app uses a local stub so the flow stays testable. /demo runs the same overlay
# but auto-verifies locally (its stand-in until real verification is wired there).
VITE_IG_VERIFY_ENABLED=0

# Your Instagram username (no @) — the account people DM the code to. ig.me/m/<this>
# deep-links straight into a DM thread with it.
VITE_IG_USERNAME=celestual.us

# Instagram Login (OAuth 2.0) — the SCALE path. When 1, the verify sheet offers
# "continue with instagram": the person logs in and Meta tells us their real @, with
# no DM, no ManyChat, no Facebook Page. Requires migration 0011 + the celestual-ig-oauth
# edge function + the four function secrets (see docs/IG-OAUTH-SETUP.md). The two vars
# below are PUBLIC by nature (they appear in the authorize URL); the client SECRET lives
# only in Supabase. Can run alongside VITE_IG_VERIFY_ENABLED (people choose) or alone
# (the DM code fallback is then hidden). When 0, the button isn't offered.
VITE_IG_OAUTH_ENABLED=0
# Your Instagram app ID (Meta → Instagram → API setup with Instagram login).
VITE_IG_OAUTH_CLIENT_ID=
# The celestual-ig-oauth function URL — must EXACTLY match the "Valid OAuth Redirect
# URIs" entry in the Meta app and the IG_OAUTH_REDIRECT_URI function secret.
VITE_IG_OAUTH_REDIRECT_URI=https://YOUR-PROJECT-REF.functions.supabase.co/celestual-ig-oauth

# Instagram @ search typeahead: requires the celestual-search edge function + a
# provider source. When 0, manual entry + validation only (no suggestions).
VITE_HANDLE_SEARCH=0

# School (.edu) email verification for community membership. When 1, joining a
# curated school requires proving you're there: a 6-digit code is emailed to an
# address at that school's domain and entered back to confirm. Requires migration
# 0007 + the celestual-edu-verify edge function + a Resend sender (see
# docs/EDU-VERIFICATION.md). When 0 (or without Supabase configured), the join
# sheet uses a local stub that auto-confirms, so the flow stays testable in dev.
# /demo always uses the stub regardless of this flag.
VITE_EDU_VERIFY_ENABLED=0

# NOTE: there is no paywall — everything is free. The limits are the three-slot
# rule (3 standing pings; retiring frees the slot) and the sixty-day lapse, both
# enforced server-side in celestual_submit (migration 0006).
